# --- Database (Supabase Postgres) ---
# Phase 1 默认使用 Supabase 直连（5432）+ sslmode=require
# 不要保留 YOUR_PASSWORD / YOUR_PROJECT_REF 这类模板占位符
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# --- NextAuth ---
# 生成方式：openssl rand -base64 32
# 不要保留 replace_me_with_a_long_random_string；
# 用[Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))生成
AUTH_SECRET=replace_me_with_a_long_random_string
AUTH_URL=http://localhost:3001

# --- Supabase Storage (Phase 2 才启用，Phase 1 保持留空) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=materials

# --- AI provider (Phase 3 才启用，Phase 1 保持留空) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
